---
import ContactCTA from '../components/ContactCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const SCARTECH_APP_URL = 'https://scartech-frontend.vercel.app/prototipo/index.html';
---

<BaseLayout
  title="Aplicativos | Scartech Solution"
  description="ScarTech — gestão para assistências técnicas e para fornecedores de peças de smartphones: OS, estoque, vendas e faturamento."
>
  <div class="apps-page">
    <section class="hero-apps">
      <p class="hero-eyebrow">Produto ScarTech</p>
      <h1 class="hero-title"><span class="highlight">Aplicativos</span></h1>
      <p class="hero-lead">
        O <strong>ScarTech</strong> é o nosso sistema de gestão para assistências técnicas e também para <strong>fornecedores de peças de smartphones</strong>:
        telas, baterias, conectores e demais itens do canal mobile. Quem opera a loja controla ordens de serviço, estoque em tempo real, vendas e
        financeiro; quem fornece peças usa o mesmo ecossistema para vender e acompanhar o relacionamento com as assistências — tudo com perfis
        separados para <em>assistência</em> e <em>fornecedor</em>.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={SCARTECH_APP_URL} target="_blank" rel="noopener noreferrer">
          Acessar o ScarTech
        </a>
      </div>
    </section>

    <section class="gallery-section" aria-labelledby="gallery-heading">
      <h2 id="gallery-heading" class="section-title">Visão do sistema</h2>
      <p class="section-intro">
        Capturas reais do protótipo: tela de entrada, painel principal com módulos (incluindo fornecedores) e criação de ordem de serviço com geração de
        PDF — o mesmo fluxo usado na gestão de assistência e no relacionamento com quem fornece peças de smartphones.
      </p>
      <div class="gallery">
        <figure class="gallery-item gallery-item--wide">
          <img
            src="/assets/aplicativos/scartech-tela-login.png"
            alt="ScarTech: página inicial com apresentação da plataforma e formulário de login"
            width="1024"
            height="349"
            loading="eager"
            decoding="async"
          />
          <figcaption>Login e apresentação — acesso seguro ao painel e mensagem clara do que a plataforma oferece.</figcaption>
        </figure>
        <figure class="gallery-item">
          <img
            src="/assets/aplicativos/scartech-dashboard.png"
            alt="ScarTech: dashboard com atalhos para ordens de serviço, faturamento, produtos, fornecedores e vendas"
            width="1024"
            height="354"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Painel inicial — visão rápida das áreas da operação, incluindo fornecedores e vendas.</figcaption>
        </figure>
        <figure class="gallery-item">
          <img
            src="/assets/aplicativos/scartech-nova-ordem-servico.png"
            alt="ScarTech: modal Nova Ordem de Serviço com dados do cliente, aparelho, defeito e opção Salvar e Gerar PDF"
            width="1024"
            height="349"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Nova ordem de serviço — cadastro completo (incluindo modelo do aparelho) e documento em PDF.</figcaption>
        </figure>
      </div>
      <div class="gallery-cta-wrap">
        <a class="btn-primary btn-primary--large" href={SCARTECH_APP_URL} target="_blank" rel="noopener noreferrer">
          Experimentar no navegador
        </a>
      </div>
    </section>

    <section class="features-section" aria-labelledby="features-heading">
      <h2 id="features-heading" class="section-title">O que o ScarTech entrega</h2>
      <div class="features-grid">
        <article class="feature-card">
          <div class="feature-icon"><Icon icon="terminal-window" size="2.25rem" color="#3b82f6" /></div>
          <h3>Ordens de serviço</h3>
          <p>Acompanhe abertura, execução e entrega com clareza para a equipe e para o cliente.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon"><Icon icon="strategy" size="2.25rem" color="#3b82f6" /></div>
          <h3>Estoque em tempo real</h3>
          <p>Peças e produtos com visão atualizada para evitar ruptura e retrabalho.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon"><Icon icon="trophy" size="2.25rem" color="#3b82f6" /></div>
          <h3>Finanças e relatórios</h3>
          <p>Base para decisões com faturamento e indicadores alinhados ao dia a dia da loja.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon"><Icon icon="paper-plane-tilt" size="2.25rem" color="#3b82f6" /></div>
          <h3>Multiperfil</h3>
          <p>Assistência técnica e fornecedores de peças de smartphones no mesmo produto, cada um com sua visão.</p>
        </article>
      </div>
    </section>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .apps-page {
    background: linear-gradient(135deg, #000000 0%, #0a0a0a 30%, #050505 60%, #000000 100%);
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
    min-height: 100vh;
    position: relative;
    z-index: 2;
    padding-top: 7rem;
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .apps-page::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.02) 0%, transparent 70%);
    animation: float 20s ease-in-out infinite;
    pointer-events: none;
    filter: blur(40px);
    z-index: -1;
  }

  @keyframes gradientShift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(30px, -30px) rotate(5deg);
    }
    66% {
      transform: translate(-20px, 20px) rotate(-5deg);
    }
  }

  .hero-apps {
    max-width: 900px;
    margin: 0 auto 3.5rem;
    padding: 0 2rem;
    text-align: center;
  }

  .hero-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
    color: #60a5fa;
    margin: 0 0 0.75rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 1.25rem;
    line-height: 1.1;
  }

  .highlight {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-lead {
    font-size: 1.15rem;
    line-height: 1.75;
    color: #94a3b8;
    margin: 0 0 2rem;
  }

  .hero-lead strong {
    color: #e2e8f0;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border: 1px solid rgba(96, 165, 250, 0.5);
    box-shadow: 0 12px 40px rgba(37, 99, 235, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 48px rgba(37, 99, 235, 0.45);
    }
  }

  .btn-primary:focus-visible {
    outline: 2px solid #93c5fd;
    outline-offset: 3px;
  }

  .btn-primary--large {
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }

  .gallery-section,
  .features-section {
    max-width: 1200px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 900;
    color: #fff;
    text-align: center;
    margin: 0 0 0.75rem;
  }

  .section-intro {
    text-align: center;
    color: #94a3b8;
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 640px;
    margin: 0 auto 2.5rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .gallery-item {
    margin: 0;
    background: rgba(30, 41, 59, 0.45);
    border: 1px solid rgba(59, 130, 246, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  @media (hover: hover) {
    .gallery-item:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 50px rgba(37, 99, 235, 0.2);
    }
  }

  .gallery-item--wide {
    grid-column: 1 / -1;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  .gallery-item figcaption {
    padding: 1rem 1.25rem 1.25rem;
    font-size: 0.9rem;
    color: #cbd5e1;
    line-height: 1.5;
  }

  .gallery-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .feature-card {
    background: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 1rem;
    padding: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .feature-icon {
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1.15rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .feature-card p {
    margin: 0;
    font-size: 0.92rem;
    color: #94a3b8;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .apps-page {
      padding-top: 12rem;
    }

    .gallery {
      grid-template-columns: 1fr;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
